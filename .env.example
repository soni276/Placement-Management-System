# Copy to .env and fill values
# For Vercel: Set these in Project → Settings → Environment Variables

# Database (use PlanetScale/Railway/etc for production - localhost won't work)
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/placement_db

# NextAuth - REQUIRED for deployment
NEXTAUTH_URL=https://your-project.vercel.app
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Email (optional - for interview notifications)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# WhatsApp/Twilio (optional)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
